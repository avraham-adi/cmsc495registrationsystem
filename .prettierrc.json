{
	"printWidth": 200,
	"tabWidth": 4,
	"useTabs": true,
	"semi": true,
	"singleQuote": true,
	"quoteProps": "preserve",
	"trailingComma": "es5",
	"bracketSpacing": true,
	"objectWrap": "preserve",
	"arrowParens": "always",
	"parser": "flow",
	"endOfLine": "lf",
	"overrides": [
		{
			"files": ["*.css", "*.scss", "*.less"],
			"options": {
				"parser": "css",
				"printWidth": 80,
				"tabWidth": 4,
				"useTabs": true,
				"singleQuote": false
			}
		}
	]
}
